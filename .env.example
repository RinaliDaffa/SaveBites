# ============================================================================
# SaveBites — Environment Variables Template
# ============================================================================
# Copy this file to .env.local and fill in the real values:
#     cp .env.example .env.local
#
# Where to find each key:
#   NEXT_PUBLIC_SUPABASE_URL      Supabase Dashboard → Project Settings → API
#   NEXT_PUBLIC_SUPABASE_ANON_KEY Supabase Dashboard → Project Settings → API
#   SUPABASE_SERVICE_ROLE_KEY     Supabase Dashboard → Project Settings → API
#                                 (click "reveal" next to service_role — key
#                                  starts with eyJhbGciOiJIUzI1NiIs...)
# ============================================================================

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://dbizcmezzdsusqymagln.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your_anon_key_here>

# Server-only. NEVER expose to the browser. The Next.js Server Actions use
# this key to bypass RLS for trusted mutations (creating listings on behalf
# of a merchant, marking orders paid, etc.).
SUPABASE_SERVICE_ROLE_KEY=<your_service_role_key_here>

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Midtrans (QRIS payments) ------------------------------------------------
# Sandbox keys are fine for local development. Get them from
# https://midtrans.com → Settings → Access Keys.
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# --- Rate Limiting (Upstash Redis) -------------------------------------------
# Production Redis-backed rate limiting. Leave blank for in-memory fallback.
# Upstash Redis no-cost tier available at https://upstash.com.
UPSTASH_REDIS_REST_URL=https://<region>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your_upstash_token>
